# All three are set in Vercel Project Settings → Environment Variables.
# Never in this file (or any committed file). This file only documents names.

# From a GitHub OAuth App at https://github.com/settings/developers.
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Random 32+ byte hex string used to HMAC-sign the OAuth CSRF state cookie.
# Generate once and paste into Vercel. Rotating it invalidates any in-flight logins.
# Example generator (do not commit the output):  openssl rand -hex 32
OAUTH_STATE_SECRET=
