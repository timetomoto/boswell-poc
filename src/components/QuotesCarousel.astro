---
// Auto-rotating quotes carousel on a solid purple ground.
// - Advances every `intervalMs` ms (default 6000)
// - Prev / next arrow controls + dot indicators
// - Pauses on hover, focus, or when `prefers-reduced-motion: reduce`
// - `aria-live=polite` so screen readers announce quote changes
// - Left/right arrow keys navigate when the carousel has focus
const {
  quotes = [],
  intervalMs = 6000,
} = Astro.props as {
  quotes: Array<{ text: string; attribution: string }>;
  intervalMs?: number;
};
---
<div class="qc" data-carousel data-interval={intervalMs} role="region" aria-roledescription="carousel" aria-label="Quotes about the Boswell Sisters" tabindex="0">
  <div class="qc__viewport" aria-live="polite" aria-atomic="true">
    {quotes.map((q, i) => (
      <figure class="qc__slide" data-slide={i} aria-hidden={i === 0 ? 'false' : 'true'} data-active={i === 0 ? 'true' : 'false'}>
        <blockquote class="qc__quote">
          <span aria-hidden="true">&ldquo;</span>{q.text}<span aria-hidden="true">&rdquo;</span>
        </blockquote>
        <figcaption class="qc__attr">— {q.attribution}</figcaption>
      </figure>
    ))}
  </div>
  <div class="qc__controls">
    <button type="button" class="qc__btn" data-prev aria-label="Previous quote">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M13 4 L7 10 L13 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <ol class="qc__dots" data-dots role="tablist" aria-label="Choose a quote">
      {quotes.map((_, i) => (
        <li>
          <button type="button" class="qc__dot" data-dot={i} role="tab" aria-selected={i === 0 ? 'true' : 'false'} aria-label={`Quote ${i + 1} of ${quotes.length}`}></button>
        </li>
      ))}
    </ol>
    <button type="button" class="qc__btn" data-next aria-label="Next quote">
      <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M7 4 L13 10 L7 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>
</div>

<script>
  const carousels = document.querySelectorAll('[data-carousel]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  carousels.forEach((root) => {
    const slides = Array.from(root.querySelectorAll('[data-slide]'));
    const dots   = Array.from(root.querySelectorAll('[data-dot]'));
    const prev   = root.querySelector('[data-prev]');
    const next   = root.querySelector('[data-next]');
    const interval = Number(root.getAttribute('data-interval')) || 6000;
    let index = 0;
    let timer: number | undefined;
    let paused = false;

    function go(to: number) {
      index = ((to % slides.length) + slides.length) % slides.length;
      slides.forEach((s, i) => {
        const active = i === index;
        s.setAttribute('data-active', String(active));
        s.setAttribute('aria-hidden', String(!active));
      });
      dots.forEach((d, i) => d.setAttribute('aria-selected', String(i === index)));
    }
    function start() {
      if (reduceMotion || paused || timer) return;
      timer = window.setInterval(() => go(index + 1), interval);
    }
    function stop() {
      if (timer) { clearInterval(timer); timer = undefined; }
    }

    prev?.addEventListener('click', () => { paused = true; stop(); go(index - 1); });
    next?.addEventListener('click', () => { paused = true; stop(); go(index + 1); });
    dots.forEach((d, i) => d.addEventListener('click', () => { paused = true; stop(); go(i); }));

    root.addEventListener('keydown', (e: Event) => {
      const key = (e as KeyboardEvent).key;
      if (key === 'ArrowLeft')  { paused = true; stop(); go(index - 1); }
      if (key === 'ArrowRight') { paused = true; stop(); go(index + 1); }
    });
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', () => { if (!paused) start(); });
    root.addEventListener('focusin',   stop);
    root.addEventListener('focusout',  () => { if (!paused) start(); });

    start();
  });
</script>

<style>
  .qc {
    position: relative;
    max-width: var(--measure-wide);
    margin-inline: auto;
    padding-block: clamp(var(--space-6), 4vw, var(--space-8));
    outline: none;
  }
  .qc:focus-visible { outline: 2px solid var(--yellow-soft); outline-offset: 8px; border-radius: 4px; }

  .qc__viewport {
    position: relative;
    min-height: 12rem;
    display: grid;
  }
  .qc__slide {
    grid-column: 1;
    grid-row: 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 500ms var(--ease-out-quart);
    margin: 0;
    text-align: center;
    padding-inline: clamp(var(--space-4), 4vw, var(--space-6));
  }
  .qc__slide[data-active='true'] { opacity: 1; pointer-events: auto; }
  @media (prefers-reduced-motion: reduce) {
    .qc__slide { transition: none; }
  }

  .qc__quote {
    font-family: var(--font-ui);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(var(--step-2), 2.4vw + 0.4rem, var(--step-4));
    line-height: var(--leading-snug);
    color: #FFFFFF;
    text-shadow: 0 1px 24px rgba(24, 22, 21, 0.35);
    max-width: 32ch;
    margin: 0 auto;
  }
  .qc__attr {
    display: block;
    margin-top: var(--space-4);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--yellow-soft);
    font-style: normal;
  }

  /* Controls */
  .qc__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .qc__btn {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid var(--yellow-soft);
    color: var(--yellow-soft);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background var(--dur) var(--ease-out-quart), color var(--dur) var(--ease-out-quart);
  }
  .qc__btn:hover, .qc__btn:focus-visible { background: var(--yellow-soft); color: var(--purple); outline: none; }
  .qc__btn:focus-visible { box-shadow: 0 0 0 3px rgba(225, 194, 99, 0.35); }
  .qc__dots {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .qc__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: rgba(225, 194, 99, 0.35);
    border: 0;
    cursor: pointer;
    padding: 0;
    transition: background var(--dur) var(--ease-out-quart), transform var(--dur) var(--ease-out-quart);
  }
  .qc__dot[aria-selected='true'] { background: var(--yellow-soft); transform: scale(1.25); }
  .qc__dot:hover { background: var(--yellow-soft); }
  .qc__dot:focus-visible { outline: 2px solid var(--yellow-soft); outline-offset: 3px; }
</style>
