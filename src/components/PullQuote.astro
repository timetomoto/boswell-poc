---
const { attribution } = Astro.props as { attribution?: string };
---
<figure class="pull-quote">
  <blockquote class="pull-quote__quote">
    <slot />
  </blockquote>
  {attribution && <figcaption class="pull-quote__attr">— {attribution}</figcaption>}
</figure>

<style>
  .pull-quote {
    max-width: var(--measure-wide);
    margin-inline: auto;
    padding-block: var(--space-7);
    text-align: center;
  }
  .pull-quote__quote {
    font-family: var(--font-ui);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(var(--step-2), 2.4vw + 0.4rem, var(--step-4));
    line-height: var(--leading-snug);
    letter-spacing: 0;
    color: var(--oxblood);
    quotes: "\201C" "\201D";
    max-width: 32ch;
    margin-inline: auto;
  }
  .ground-ink .pull-quote__quote { color: var(--champagne); }
  .pull-quote__quote::before { content: open-quote; margin-right: 0.1em; }
  .pull-quote__quote::after { content: close-quote; margin-left: 0.1em; }
  .pull-quote__attr {
    margin-top: var(--space-4);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--brass);
  }
</style>
