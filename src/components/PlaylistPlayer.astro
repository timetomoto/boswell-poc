---
// Playlist player — simple HTML5 audio + click-to-play track list.
// Tracks are passed in as a prop; each has title / artist / year / audio URL.
// Accessible: proper button semantics, aria-current on the active track,
// keyboard navigation, screen-reader-friendly status text.
const {
  tracks = [],
} = Astro.props as {
  tracks: Array<{
    title: string;
    artist?: string;
    year?: string | number;
    duration?: string;
    audio: string;
  }>;
};
---
{tracks.length > 0 && (
  <div class="pp" data-playlist>
    <div class="pp__player">
      <div class="pp__now">
        <span class="pp__now-eyebrow">Now playing</span>
        <span class="pp__now-title" data-title>{tracks[0].title}</span>
        {(tracks[0].artist || tracks[0].year) && (
          <span class="pp__now-meta" data-meta>
            {[tracks[0].artist, tracks[0].year].filter(Boolean).join(' · ')}
          </span>
        )}
      </div>

      <div class="pp__controls">
        <button type="button" class="pp__btn" data-prev aria-label="Previous track">
          <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M6 4 L6 16 M14 4 L6 10 L14 16 Z" fill="currentColor"/></svg>
        </button>
        <button type="button" class="pp__btn pp__btn--play" data-play aria-label="Play or pause">
          <svg class="pp__icon-play" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 5 L19 12 L7 19 Z" fill="currentColor"/></svg>
          <svg class="pp__icon-pause" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" style="display:none"><path d="M7 5 h4 v14 h-4 z M13 5 h4 v14 h-4 z" fill="currentColor"/></svg>
        </button>
        <button type="button" class="pp__btn" data-next aria-label="Next track">
          <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M14 4 L14 16 M6 4 L14 10 L6 16 Z" fill="currentColor"/></svg>
        </button>
      </div>

      <div class="pp__progress-wrap">
        <span class="pp__time" data-current>0:00</span>
        <div class="pp__progress" data-progress-container
             role="slider" tabindex="0"
             aria-label="Seek within track"
             aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
          <div class="pp__progress-bar" data-progress></div>
        </div>
        <span class="pp__time" data-duration>--:--</span>
      </div>

      <audio data-audio preload="metadata"></audio>
    </div>

    <ol class="pp__list" data-list role="list">
      {tracks.map((t, i) => (
        <li>
          <button type="button" class="pp__track" data-track={i} aria-current={i === 0 ? 'true' : 'false'}>
            <span class="pp__track-index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="pp__track-body">
              <span class="pp__track-title">{t.title}</span>
              {(t.artist || t.year) && <span class="pp__track-meta">{[t.artist, t.year].filter(Boolean).join(' · ')}</span>}
            </span>
            {t.duration && <span class="pp__track-duration">{t.duration}</span>}
            <span class="pp__track-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18"><path d="M5 3 L14 9 L5 15 Z" fill="currentColor"/></svg>
            </span>
          </button>
        </li>
      ))}
    </ol>

    <script type="application/json" data-tracks set:html={JSON.stringify(tracks)}></script>
  </div>
)}

<script>
  function fmt(s: number) {
    if (!Number.isFinite(s)) return '--:--';
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60).toString().padStart(2, '0');
    return `${m}:${sec}`;
  }

  document.querySelectorAll('[data-playlist]').forEach((root) => {
    const tracks = JSON.parse(root.querySelector('[data-tracks]')?.textContent ?? '[]');
    if (!tracks.length) return;

    const audio    = root.querySelector('[data-audio]') as HTMLAudioElement;
    const titleEl  = root.querySelector('[data-title]');
    const metaEl   = root.querySelector('[data-meta]');
    const playBtn  = root.querySelector('[data-play]');
    const prevBtn  = root.querySelector('[data-prev]');
    const nextBtn  = root.querySelector('[data-next]');
    const iconPlay = root.querySelector('.pp__icon-play') as HTMLElement;
    const iconPause = root.querySelector('.pp__icon-pause') as HTMLElement;
    const progContainer = root.querySelector('[data-progress-container]');
    const progBar  = root.querySelector('[data-progress]') as HTMLElement;
    const curEl    = root.querySelector('[data-current]');
    const durEl    = root.querySelector('[data-duration]');
    const trackBtns = Array.from(root.querySelectorAll('[data-track]'));

    let idx = 0;

    function load(i: number, play = false) {
      idx = ((i % tracks.length) + tracks.length) % tracks.length;
      const t = tracks[idx];
      audio.src = t.audio;
      if (titleEl) titleEl.textContent = t.title;
      if (metaEl)  metaEl.textContent  = [t.artist, t.year].filter(Boolean).join(' · ');
      trackBtns.forEach((b, i) => b.setAttribute('aria-current', String(i === idx)));
      if (play) audio.play().catch(() => {});
    }

    playBtn?.addEventListener('click', () => {
      if (audio.paused) audio.play().catch(() => {}); else audio.pause();
    });
    prevBtn?.addEventListener('click', () => load(idx - 1, !audio.paused));
    nextBtn?.addEventListener('click', () => load(idx + 1, !audio.paused));
    trackBtns.forEach((b, i) => b.addEventListener('click', () => load(i, true)));

    audio.addEventListener('play',  () => { iconPlay.style.display = 'none'; iconPause.style.display = ''; });
    audio.addEventListener('pause', () => { iconPlay.style.display = '';     iconPause.style.display = 'none'; });
    audio.addEventListener('ended', () => load(idx + 1, true));
    audio.addEventListener('loadedmetadata', () => { if (durEl) durEl.textContent = fmt(audio.duration); });
    audio.addEventListener('timeupdate', () => {
      if (curEl) curEl.textContent = fmt(audio.currentTime);
      if (audio.duration) {
        const pct = (audio.currentTime / audio.duration) * 100;
        if (progBar) progBar.style.width = `${pct}%`;
        progContainer?.setAttribute('aria-valuenow', String(Math.round(pct)));
      }
    });

    progContainer?.addEventListener('click', (e: Event) => {
      const rect = (progContainer as HTMLElement).getBoundingClientRect();
      const pct = ((e as MouseEvent).clientX - rect.left) / rect.width;
      if (audio.duration) audio.currentTime = pct * audio.duration;
    });

    /* Keyboard seeking on the progress bar — WCAG 2.1.1 */
    progContainer?.addEventListener('keydown', (e: Event) => {
      const key = (e as KeyboardEvent).key;
      if (!audio.duration) return;
      const step = 5;
      if (key === 'ArrowRight' || key === 'ArrowUp')   { audio.currentTime = Math.min(audio.duration, audio.currentTime + step); e.preventDefault(); }
      if (key === 'ArrowLeft'  || key === 'ArrowDown') { audio.currentTime = Math.max(0,              audio.currentTime - step); e.preventDefault(); }
      if (key === 'Home')                              { audio.currentTime = 0;                                                   e.preventDefault(); }
      if (key === 'End')                               { audio.currentTime = audio.duration;                                      e.preventDefault(); }
      if (key === ' ' || key === 'Enter')              { if (audio.paused) audio.play().catch(() => {}); else audio.pause();      e.preventDefault(); }
    });

    load(0, false);
  });
</script>

<style>
  .pp {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(var(--space-5), 3vw, var(--space-7));
    max-width: var(--measure-max);
    margin-inline: auto;
    background: color-mix(in oklab, var(--paper) 96%, var(--purple) 4%);
    border: 1px solid var(--paper-hairline);
    padding: clamp(var(--space-5), 2.4vw, var(--space-7));
  }
  @media (max-width: 820px) { .pp { grid-template-columns: 1fr; } }

  .pp__player { display: flex; flex-direction: column; gap: var(--space-4); }

  .pp__now { display: flex; flex-direction: column; gap: var(--space-1); }
  .pp__now-eyebrow {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--2);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--purple);
  }
  .pp__now-title {
    font-family: var(--font-display);
    font-size: clamp(var(--step-3), 2vw + 0.3rem, var(--step-4));
    line-height: 1.1;
    color: var(--ink);
  }
  .pp__now-meta {
    font-family: var(--font-body);
    font-size: var(--step-0);
    color: var(--text-on-paper-muted);
  }

  .pp__controls { display: flex; align-items: center; gap: var(--space-4); }
  .pp__btn {
    width: 44px; height: 44px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid var(--purple);
    color: var(--purple);
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0; cursor: pointer;
    transition: background var(--dur) var(--ease-out-quart), color var(--dur) var(--ease-out-quart);
  }
  .pp__btn:hover, .pp__btn:focus-visible { background: var(--purple); color: var(--paper); outline: none; }
  .pp__btn--play { width: 56px; height: 56px; background: var(--purple); color: var(--paper); }
  .pp__btn--play:hover, .pp__btn--play:focus-visible { background: var(--oxblood); border-color: var(--oxblood); }

  .pp__progress-wrap { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: var(--space-3); }
  .pp__time { font-family: var(--font-ui); font-size: var(--step--1); color: var(--text-on-paper-muted); font-variant-numeric: tabular-nums; }
  .pp__progress { position: relative; height: 6px; background: color-mix(in oklab, var(--paper) 85%, var(--purple) 15%); cursor: pointer; outline: none; }
  .pp__progress:focus-visible { outline: 2px solid var(--purple); outline-offset: 3px; }
  .pp__progress-bar { position: absolute; left: 0; top: 0; bottom: 0; width: 0%; background: var(--purple); transition: width 120ms linear; }

  .pp__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    max-height: 14rem;    /* ≈ 3 tracks visible */
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--purple) transparent;
  }
  .pp__list::-webkit-scrollbar { width: 6px; }
  .pp__list::-webkit-scrollbar-thumb { background: var(--purple); border-radius: 3px; }
  .pp__track {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: var(--space-3);
    align-items: center;
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--paper-hairline);
    padding: var(--space-3) var(--space-4);
    text-align: left;
    cursor: pointer;
    color: var(--ink);
    transition: background var(--dur) var(--ease-out-quart);
  }
  .pp__track:last-child { border-bottom: 0; }
  .pp__track:hover, .pp__track:focus-visible { background: color-mix(in oklab, var(--purple) 6%, transparent); outline: none; }
  .pp__track[aria-current='true'] { background: color-mix(in oklab, var(--purple) 10%, transparent); }
  .pp__track-index { font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1); color: var(--purple); font-feature-settings: 'tnum'; min-width: 2ch; }
  .pp__track-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .pp__track-title { font-family: var(--font-body); font-weight: 500; font-size: var(--step-0); }
  .pp__track-meta { font-family: var(--font-ui); font-size: var(--step--2); color: var(--text-on-paper-muted); }
  .pp__track-duration { font-family: var(--font-ui); font-size: var(--step--1); color: var(--text-on-paper-muted); font-variant-numeric: tabular-nums; font-feature-settings: 'tnum'; }
  .pp__track-icon { color: var(--purple); opacity: 0; transition: opacity var(--dur) var(--ease-out-quart); }
  .pp__track:hover .pp__track-icon,
  .pp__track[aria-current='true'] .pp__track-icon { opacity: 1; }
</style>
