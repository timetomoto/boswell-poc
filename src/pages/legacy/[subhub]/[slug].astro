---
import Base from '../../../layouts/Base.astro';
import MusicBackdrop from '../../../components/MusicBackdrop.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const features = await getCollection('legacyFeatures');
  return features.map(f => ({
    params: { subhub: f.data.subhub, slug: f.id },
    props: { feature: f },
  }));
}

const { feature } = Astro.props;
const { Content } = await render(feature);

const SUBHUB_LABEL: Record<string, string> = {
  bozcasts: 'Bozcasts',
  ascap: 'ASCAP Recognition',
  'boz-of-the-month': 'Boz of the Month',
  feature: 'Community',
};
const subhubLabel = SUBHUB_LABEL[feature.data.subhub] ?? feature.data.subhub;

const all = (await getCollection('legacyFeatures'))
  .filter(f => f.data.subhub === feature.data.subhub)
  .sort((a, b) => a.id.localeCompare(b.id));
const currentIdx = all.findIndex(f => f.id === feature.id);
const prev = all.length > 1 ? (currentIdx > 0 ? all[currentIdx - 1] : all[all.length - 1]) : null;
const next = all.length > 1 ? (currentIdx < all.length - 1 ? all[currentIdx + 1] : all[0]) : null;
---
<Base title={feature.data.title} description={feature.data.date}>
  <section class="feature-hero ground-purple">
    <MusicBackdrop variant="fleur" opacity={0.07} color="var(--yellow-soft)" />
    <div class="container-narrow feature-hero__inner">
      <a href="/legacy/" class="feature-hero__back">← Legacy · {subhubLabel}</a>
      <h1 class="feature-hero__title">{feature.data.title}</h1>
      {feature.data.date && <p class="feature-hero__meta">{feature.data.date}</p>}
    </div>
  </section>

  <section class="section ground-paper">
    <div class="container-narrow prose feature-body">
      <Content />
      {feature.data.externalLink && (
        <p class="feature-external">
          <a href={feature.data.externalLink} target="_blank" rel="noopener noreferrer">Visit the source →</a>
        </p>
      )}
    </div>
  </section>

  {(prev || next) && (
    <nav class="section-tight ground-paper feature-nav" aria-label="Legacy navigation">
      <div class="container feature-nav__inner">
        {prev && (
          <a href={`/legacy/${prev.data.subhub}/${prev.id}/`} class="feature-nav__link feature-nav__link--prev">
            <span class="feature-nav__label">Previous</span>
            <span class="feature-nav__title">{prev.data.title}</span>
          </a>
        )}
        <a href="/legacy/" class="feature-nav__link feature-nav__link--all">
          <span class="feature-nav__label">All</span>
          <span class="feature-nav__title">Legacy</span>
        </a>
        {next && (
          <a href={`/legacy/${next.data.subhub}/${next.id}/`} class="feature-nav__link feature-nav__link--next">
            <span class="feature-nav__label">Next</span>
            <span class="feature-nav__title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}
</Base>

<style>
  .feature-hero { padding-block: clamp(var(--space-6), 4vw, var(--space-8)); position: relative; overflow: hidden; }
  .feature-hero__inner { position: relative; z-index: 1; }
  .feature-hero__back { display: block; width: fit-content; font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase; color: var(--yellow-soft); border: 0; margin-bottom: var(--space-5); }
  .feature-hero__back:hover { color: #F5DE8C; }
  .feature-hero__title { font-family: var(--font-display); font-weight: 300; font-size: clamp(var(--step-5), 5vw + 0.3rem, var(--step-7)); line-height: 1.05; letter-spacing: var(--track-tight); color: #F5EAD1; margin: 0; max-width: 28ch; }
  .feature-hero__meta { margin-top: var(--space-4); font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase; color: var(--yellow-soft); }

  .prose { font-family: var(--font-body); font-size: var(--step-1); line-height: var(--leading-loose); color: var(--text-on-paper); }
  .prose :global(p) { max-width: 62ch; }
  .prose :global(p) + :global(p), .prose :global(p) + :global(h2), .prose :global(p) + :global(h3), .prose :global(p) + :global(h4) { margin-top: var(--space-4); }
  .prose :global(h2), .prose :global(h3), .prose :global(h4) { margin-top: var(--space-6); margin-bottom: var(--space-3); font-family: var(--font-display); font-weight: 400; letter-spacing: var(--track-tight); }
  .prose :global(h2) { font-size: var(--step-3); }
  .prose :global(h3) { font-size: var(--step-2); }
  .prose :global(h4) { font-size: var(--step--1); font-family: var(--font-ui); font-weight: 500; letter-spacing: var(--track-caps); text-transform: uppercase; color: var(--purple); margin-top: var(--space-8); margin-bottom: var(--space-4); }
  .prose :global(img) { max-width: 100%; height: auto; margin: var(--space-4) 0; }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(em), .prose :global(i) { font-family: var(--font-ui); font-style: italic; }
  .prose :global(blockquote) { border-left: 3px solid var(--brass); padding-left: var(--space-4); margin: var(--space-5) 0; font-family: var(--font-ui); font-style: italic; font-size: var(--step-0); color: var(--oxblood); }

  .feature-external { margin-top: var(--space-6); font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase; }

  .feature-nav { border-top: 1px solid var(--paper-hairline); }
  .feature-nav__inner { display: grid; grid-template-columns: 1fr auto 1fr; gap: var(--space-5); align-items: center; }
  .feature-nav__link { display: inline-flex; flex-direction: column; gap: var(--space-1); border: 0; padding-block: var(--space-3); max-width: 22rem; }
  .feature-nav__link--prev { text-align: left; }
  .feature-nav__link--all { text-align: center; }
  .feature-nav__link--next { text-align: right; justify-self: end; }
  .feature-nav__label { font-family: var(--font-ui); font-weight: 500; font-size: var(--step--2); letter-spacing: var(--track-caps); text-transform: uppercase; color: var(--text-on-paper-muted); }
  .feature-nav__title { font-family: var(--font-display); font-size: var(--step-1); color: var(--ink); line-height: 1.15; }
  @media (max-width: 640px) {
    .feature-nav__inner { grid-template-columns: 1fr; text-align: center; }
    .feature-nav__link { text-align: center; justify-self: center; max-width: none; }
  }
</style>
