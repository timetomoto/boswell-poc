---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import PullQuote from '../../components/PullQuote.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import MusicBackdrop from '../../components/MusicBackdrop.astro';
import { getEntry, getCollection, render } from 'astro:content';

const page = await getEntry('pages', 'music');
if (!page) throw new Error('Missing src/content/pages/music.md');
const { Content: PageContent } = await render(page);

const lessons = (await getCollection('lessons')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);

const charts = await getEntry('pages', 'charts');
const reviews = await getEntry('pages', 'reviews');
---
<Base title={page.data.title as string} description={page.data.subtitle as string | undefined}>
  <Hero
    eyebrow={page.data.eyebrow as string | undefined}
    title={page.data.title as string}
    subtitle={page.data.subtitle as string | undefined}
    image={page.data.heroImage as string | undefined}
    imageAlt={page.data.heroImageAlt as string | undefined}
    height="medium"
    layout="full-bleed"
    align="center"
  />

  <section class="section ground-paper section-intro">
    <MusicBackdrop variant="jazz-club" opacity={0.06} color="var(--purple)" />
    <div class="container-narrow prose">
      <PageContent />
    </div>
  </section>

  <SectionDivider variant="jazz" color="purple" />

  <section class="section ground-paper lessons-grid">
    <div class="container">
      <header class="lessons-grid__head">
        <span class="eyebrow eyebrow--purple">Boz Beat Lessons</span>
        <h2 class="lessons-grid__title">Five keys to the Boswell sound</h2>
        <p class="lessons-grid__lede">Cynthia Lucas, one of the best-known Boz historians, narrates five audio lessons that unpack how the Sisters actually did what they did.</p>
      </header>
      <ol class="lessons-cards" role="list">
        {lessons.map(l => (
          <li class="lesson-card">
            <a href={`/media/lessons/${l.data.order}/`} class="lesson-card__link">
              <div class="lesson-card__num">
                <span class="lesson-card__num-label">Lesson</span>
                <span class="lesson-card__num-value">{String(l.data.order).padStart(2, '0')}</span>
              </div>
              <div class="lesson-card__body">
                <h3 class="lesson-card__title">{l.data.title}</h3>
                {l.data.summary && <p class="lesson-card__summary">{l.data.summary}</p>}
              </div>
              <div class="lesson-card__cta">
                <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="12" r="11" fill="none" stroke="currentColor" stroke-width="1"/>
                  <path d="M9 7 L17 12 L9 17 Z" fill="currentColor"/>
                </svg>
                <span>Listen</span>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section ground-purple music-teasers">
    <MusicBackdrop variant="vinyl" opacity={0.10} color="var(--yellow-soft)" />
    <div class="container music-teasers__grid">
      {charts && (
        <a href="/media/charts/" class="music-teaser">
          <span class="eyebrow music-teaser__eyebrow">Discography</span>
          <h3 class="music-teaser__title">Boz on the Charts</h3>
          <p class="music-teaser__body">Chart positions from Brunswick 6083 in 1931 to Decca in the late 1930s and beyond — how the Boswell Sisters and Connee actually rated with the record-buying public.</p>
          <span class="music-teaser__cta">
            Explore the charts
            <svg width="20" height="10" viewBox="0 0 20 10" aria-hidden="true">
              <path d="M0 5 H17 M13 1 L17 5 L13 9" stroke="currentColor" stroke-width="1" fill="none"/>
            </svg>
          </span>
        </a>
      )}
      {reviews && (
        <a href="/media/reviews/" class="music-teaser">
          <span class="eyebrow music-teaser__eyebrow">Reviews</span>
          <h3 class="music-teaser__title">Album reviews from the experts</h3>
          <p class="music-teaser__body">Storyville volumes, Singing the Blues, Shout Sisters Shout, and the lost 1957 RCA classic — hand-picked reviews for anyone starting a Boz collection.</p>
          <span class="music-teaser__cta">
            Read the reviews
            <svg width="20" height="10" viewBox="0 0 20 10" aria-hidden="true">
              <path d="M0 5 H17 M13 1 L17 5 L13 9" stroke="currentColor" stroke-width="1" fill="none"/>
            </svg>
          </span>
        </a>
      )}
    </div>
  </section>
</Base>

<style>
  .section-intro, .lessons-grid, .music-teasers { position: relative; overflow: hidden; }

  /* Prose block, shared with sisters pages */
  .prose { font-family: var(--font-body); font-size: var(--step-1); line-height: var(--leading-loose); color: var(--text-on-paper); position: relative; z-index: 1; }
  .prose :global(p) { max-width: 62ch; }
  .prose :global(p) + :global(p), .prose :global(p) + :global(h2), .prose :global(p) + :global(h3), .prose :global(p) + :global(h4) { margin-top: var(--space-4); }
  .prose :global(h2), .prose :global(h3), .prose :global(h4) { margin-top: var(--space-6); margin-bottom: var(--space-3); font-family: var(--font-display); font-weight: 400; letter-spacing: var(--track-tight); }
  .prose :global(h2) { font-size: var(--step-3); }
  .prose :global(h3) { font-size: var(--step-2); }
  .prose :global(blockquote) { border-left: 3px solid var(--brass); padding-left: var(--space-4); margin: var(--space-5) 0; font-family: var(--font-ui); font-style: italic; font-size: var(--step-0); color: var(--oxblood); }

  /* Lessons grid */
  .lessons-grid__head { max-width: var(--measure-wide); margin-bottom: var(--space-6); }
  .lessons-grid__title { margin-top: var(--space-2); font-family: var(--font-display); font-size: clamp(var(--step-4), 3.5vw + 0.3rem, var(--step-6)); font-weight: 300; letter-spacing: var(--track-tight); }
  .lessons-grid__lede { margin-top: var(--space-3); font-family: var(--font-body); font-size: var(--step-1); line-height: var(--leading-loose); color: var(--text-on-paper); max-width: 60ch; }

  .lessons-cards { display: flex; flex-direction: column; gap: 0; margin: 0; padding: 0; list-style: none; border-top: 1px solid var(--paper-hairline); position: relative; z-index: 1; }
  .lesson-card { border-bottom: 1px solid var(--paper-hairline); position: relative; background: color-mix(in oklab, var(--paper) 97%, var(--purple) 3%); }
  .lesson-card::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--purple); opacity: 0.9; }
  .lesson-card__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(var(--space-4), 3vw, var(--space-6));
    align-items: center;
    padding: clamp(var(--space-5), 2.4vw, var(--space-6));
    padding-left: calc(clamp(var(--space-5), 2.4vw, var(--space-6)) + 8px);
    border: 0;
    transition: background var(--dur) var(--ease-out-quart);
  }
  .lesson-card__link:hover, .lesson-card__link:focus-visible { background: color-mix(in oklab, var(--purple) 6%, transparent); }
  .lesson-card__num { display: flex; flex-direction: column; align-items: center; gap: var(--space-1); min-width: 4rem; }
  .lesson-card__num-label { font-family: var(--font-ui); font-weight: 500; font-size: var(--step--2); letter-spacing: var(--track-caps); text-transform: uppercase; color: var(--text-on-paper-muted); }
  .lesson-card__num-value { font-family: var(--font-display); font-size: var(--step-5); font-weight: 300; color: var(--purple); line-height: 1; font-feature-settings: 'tnum'; }
  .lesson-card__body { min-width: 0; }
  .lesson-card__title { font-family: var(--font-display); font-size: clamp(var(--step-3), 2vw, var(--step-4)); font-weight: 400; letter-spacing: var(--track-tight); color: var(--ink); margin: 0; }
  .lesson-card__summary { margin-top: var(--space-2); font-family: var(--font-body); font-size: var(--step-0); line-height: var(--leading-normal); color: var(--text-on-paper); max-width: 62ch; }
  .lesson-card__cta { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--purple); font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase; }
  .lesson-card__cta svg { transition: transform var(--dur) var(--ease-out-quart); }
  .lesson-card__link:hover .lesson-card__cta svg { transform: scale(1.1); }
  @media (max-width: 640px) {
    .lesson-card__link { grid-template-columns: auto 1fr; row-gap: var(--space-3); }
    .lesson-card__cta { grid-column: 1 / -1; justify-content: flex-end; }
  }

  /* Music sub-page teasers */
  .music-teasers__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(var(--space-4), 2.4vw, var(--space-6)); position: relative; z-index: 1; }
  @media (max-width: 820px) { .music-teasers__grid { grid-template-columns: 1fr; } }
  .music-teaser {
    display: flex; flex-direction: column; gap: var(--space-3);
    padding: clamp(var(--space-5), 2.4vw, var(--space-6));
    border: 1px solid rgba(225, 194, 99, 0.35);
    background: color-mix(in oklab, var(--purple) 92%, black);
    color: #F5EAD1;
    text-decoration: none;
    transition: transform var(--dur) var(--ease-out-quart), background var(--dur) var(--ease-out-quart);
  }
  .music-teaser:hover { transform: translateY(-3px); background: color-mix(in oklab, var(--purple) 88%, black); }
  .music-teaser__eyebrow { color: var(--yellow-soft); }
  .music-teaser__title { font-family: var(--font-display); font-size: clamp(var(--step-3), 2.4vw, var(--step-4)); font-weight: 400; letter-spacing: var(--track-tight); color: #F5EAD1; margin: 0; }
  .music-teaser__body { font-family: var(--font-body); font-size: var(--step-0); line-height: var(--leading-normal); color: rgba(245, 234, 209, 0.85); margin: 0; max-width: 46ch; }
  .music-teaser__cta { margin-top: auto; display: inline-flex; align-items: center; gap: var(--space-2); color: var(--yellow-soft); font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase; padding-top: var(--space-3); }
  .music-teaser:hover .music-teaser__cta svg { transform: translateX(4px); }
  .music-teaser__cta svg { transition: transform var(--dur) var(--ease-out-quart); }
</style>
