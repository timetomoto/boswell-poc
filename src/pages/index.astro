---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import PullQuote from '../components/PullQuote.astro';
import MusicBackdrop from '../components/MusicBackdrop.astro';
import { getEntry } from 'astro:content';

const home = await getEntry('pages', 'home');
const data = (home?.data ?? {}) as any;

const sections = [
  { label: 'The Sisters', href: '/sisters/', accent: 'brass',  kicker: 'Bios and Timelines', blurb: 'Three sisters from New Orleans. Their lives, in their own rhythm.' },
  { label: 'Music',       href: '/music/',   accent: 'purple', kicker: 'The Sound',           blurb: 'Boz Beat lessons, chart positions, and the reviews that recognized them.' },
  { label: 'Press',       href: '/press/',   accent: 'copper', kicker: 'Vintage and Modern',  blurb: 'A century of writing on the Boswells, from 1930s dailies to modern press.' },
  { label: 'Legacy',      href: '/legacy/',  accent: 'yellow', kicker: 'Influence Carried',   blurb: 'Tribute performers, Bozcasts, and scholarship keeping the sound alive.' },
  { label: 'About',       href: '/about/',   accent: 'brass',  kicker: 'The Non-Profit',      blurb: 'The organization behind Bozzies.org, and how to support the work.' },
];
---
<Base title={data.title as string} description={data.introLede as string | undefined}>
  <Hero
    eyebrow={data.eyebrow as string | undefined}
    title={data.title as string}
    tagline={data.tagline as string | undefined}
    subtitle={data.subtitle as string | undefined}
    image={data.heroImage as string}
    imageAlt={data.heroImageAlt as string | undefined}
    imageCredit={data.heroCredit as string | undefined}
    height="tall"
    layout="split"
  />

  {(data.introLede || data.introBody) && (
    <section class="section ground-paper intro-section">
      <MusicBackdrop variant="jazz-club" opacity={0.09} color="var(--purple)" />
      <div class="container-narrow intro">
        {data.introEyebrow && <span class="eyebrow eyebrow--purple">{data.introEyebrow}</span>}
        {data.introLede && <p class="intro__lede">{data.introLede}</p>}
        {data.introBody && <p class="intro__body">{data.introBody}</p>}
      </div>
    </section>
  )}

  {/* Featured / promo section — bourbon gold ground */}
  {data.promoCards && data.promoCards.length > 0 && (
    <section class="section ground-gold promo-section">
      <MusicBackdrop variant="fleur" opacity={0.11} color="var(--purple)" />
      <div class="container">
        {(data.promoEyebrow || data.promoTitle) && (
          <header class="promo-section__head">
            {data.promoEyebrow && <span class="eyebrow eyebrow--purple">{data.promoEyebrow}</span>}
            {data.promoTitle && <h2 class="promo-section__title">{data.promoTitle}</h2>}
          </header>
        )}
        <ul class="promo-grid" role="list">
          {data.promoCards.slice(0, 3).map((c: any) => (
            <li class="promo-card">
              <a class="promo-card__link" href={c.link} {...(c.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                {c.image && (
                  <div class="promo-card__image-wrap">
                    <img class="promo-card__image" src={c.image} alt={c.imageAlt || ''} loading="lazy" />
                  </div>
                )}
                <div class="promo-card__body">
                  {c.kicker && <span class="promo-card__kicker">{c.kicker}</span>}
                  <h3 class="promo-card__title">{c.title}</h3>
                  {c.subtitle && <p class="promo-card__subtitle">{c.subtitle}</p>}
                  {c.description && <p class="promo-card__desc">{c.description}</p>}
                  <span class="promo-card__cta">
                    {c.linkLabel || (c.external ? 'Read more' : 'Read the article')}
                    <svg class="promo-card__arrow" width="18" height="10" viewBox="0 0 18 10" aria-hidden="true">
                      <path d="M0 5 H15 M11 1 L15 5 L11 9" stroke="currentColor" stroke-width="1" fill="none"/>
                    </svg>
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <SectionDivider variant="jazz" color="purple" />

  <section class="section ground-paper sections-index">
    <MusicBackdrop variant="chevrons" opacity={0.04} color="var(--purple)" />
    <div class="container">
      {(data.sectionsEyebrow || data.sectionsTitle) && (
        <header class="sections-index__head">
          {data.sectionsEyebrow && <span class="eyebrow eyebrow--yellow">{data.sectionsEyebrow}</span>}
          {data.sectionsTitle && <h2 class="sections-index__title">{data.sectionsTitle}</h2>}
        </header>
      )}
      <ul class="sections-index__grid" role="list">
        {sections.map((s, i) => (
          <li class={`sections-index__card sections-index__card--${s.accent}`}>
            <a href={s.href} class="sections-index__link">
              <span class="sections-index__num">{String(i + 1).padStart(2, '0')}</span>
              <div class="sections-index__body">
                <span class="sections-index__kicker">{s.kicker}</span>
                <span class="sections-index__label">{s.label}</span>
                <span class="sections-index__blurb">{s.blurb}</span>
              </div>
              <span class="sections-index__arrow" aria-hidden="true">
                <svg width="28" height="10" viewBox="0 0 28 10" fill="none">
                  <path d="M0 5 H25 M20 1 L25 5 L20 9" stroke="currentColor" stroke-width="1" fill="none"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
        {/* Sixth cell — bold fleur-de-lis anchor, closing the grid with a New Orleans flourish */}
        <li class="sections-index__fleur" aria-hidden="true">
          <svg viewBox="0 0 140 180" width="100%" height="100%">
            <g fill="var(--purple)" stroke="var(--purple)" stroke-width="2.2" stroke-linejoin="round" transform="translate(70 100)">
              {/* Central spike */}
              <path d="M0 -80 C 14 -58, 10 -32, 0 -20 C -10 -32, -14 -58, 0 -80 Z"/>
              {/* Right petal */}
              <path d="M0 -20 C 28 -36, 42 -14, 32 8 C 24 -2, 12 -6, 0 -10" stroke-width="2.4"/>
              {/* Left petal */}
              <path d="M0 -20 C -28 -36, -42 -14, -32 8 C -24 -2, -12 -6, 0 -10" stroke-width="2.4"/>
              {/* Central band (horizontal wrap) */}
              <rect x="-36" y="8" width="72" height="8" rx="2" stroke-width="0"/>
              {/* Lower stem */}
              <path d="M0 16 L 0 52" fill="none" stroke-width="3"/>
              {/* Cross-tie */}
              <path d="M-16 36 L 16 36" fill="none" stroke-width="3"/>
              {/* Center jewel */}
              <circle cx="0" cy="12" r="4" stroke-width="0"/>
            </g>
          </svg>
        </li>
      </ul>
    </div>
  </section>

  <SectionDivider variant="bar-line" color="yellow" />

  {data.quote && (
    <section class="section ground-purple quote-section">
      <MusicBackdrop variant="notes" opacity={0.11} color="var(--yellow-soft)" />
      <MusicBackdrop variant="staves" opacity={0.06} color="var(--yellow-soft)" />
      <div class="container">
        <PullQuote attribution={data.quoteAttribution as string | undefined}>
          {data.quote}
        </PullQuote>
      </div>
    </section>
  )}

  <SectionDivider variant="second-line" color="yellow" />

  {(data.donateTitle || data.donateBody) && (
    <section class="section ground-paper donate-teaser">
      <MusicBackdrop variant="vinyl" opacity={0.08} color="var(--purple)" />
      <div class="container-narrow donate-teaser__inner">
        {data.donateEyebrow && <span class="eyebrow eyebrow--purple">{data.donateEyebrow}</span>}
        {data.donateTitle && <h2 class="donate-teaser__title">{data.donateTitle}</h2>}
        {data.donateBody && <p class="donate-teaser__body">{data.donateBody}</p>}
        <a href="/donate/" class="btn btn--purple">Donate</a>
      </div>
    </section>
  )}
</Base>

<style>
  .intro-section, .sections-index, .quote-section, .donate-teaser, .promo-section { position: relative; overflow: hidden; }

  /* --- Featured / promo section --- */
  .promo-section__head { text-align: center; max-width: var(--measure-wide); margin-inline: auto; margin-bottom: clamp(var(--space-4), 1.6vw, var(--space-6)); position: relative; z-index: 1; }
  .promo-section__title {
    margin-top: var(--space-3);
    font-family: var(--font-display);
    font-size: clamp(var(--step-4), 3.5vw + 0.3rem, var(--step-6));
    font-weight: 300;
  }
  .promo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(var(--space-5), 2.4vw, var(--space-6));
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) { .promo-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .promo-grid { grid-template-columns: 1fr; } }
  .promo-card {
    background: var(--paper);
    border: 1px solid var(--paper-hairline);
    position: relative;
    isolation: isolate;
    transition: transform var(--dur) var(--ease-out-quart), box-shadow var(--dur) var(--ease-out-quart);
  }
  .promo-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px -18px rgba(24, 22, 21, 0.35);
  }
  /* Small Deco top-right corner accent on each card */
  .promo-card::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 24px; height: 24px;
    border-top: 1px solid var(--brass);
    border-right: 1px solid var(--brass);
    opacity: 0.65;
    pointer-events: none;
    z-index: 2;
  }
  .promo-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 0;
    color: inherit;
  }
  .promo-card__image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: color-mix(in oklab, var(--paper) 92%, var(--purple) 8%);
  }
  .promo-card__image {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.06);
    transition: transform 600ms var(--ease-out-quart), filter var(--dur) var(--ease-out-quart);
  }
  .promo-card__link:hover .promo-card__image {
    transform: scale(1.03);
    filter: grayscale(1) contrast(1.1) brightness(1.03);
  }
  .promo-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: clamp(var(--space-5), 2vw, var(--space-6));
    flex: 1;
  }
  .promo-card__kicker {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--purple);
  }
  .promo-card__title {
    font-family: var(--font-display);
    font-size: clamp(var(--step-3), 1.8vw + 0.4rem, var(--step-4));
    font-weight: 400;
    line-height: var(--leading-snug);
    letter-spacing: var(--track-tight);
    color: var(--ink);
    margin-top: calc(var(--space-1) * -1);
  }
  .promo-card__subtitle {
    font-family: var(--font-ui);
    font-style: italic;
    color: var(--text-on-paper-muted);
    font-size: var(--step-0);
    margin-top: calc(var(--space-2) * -1);
  }
  .promo-card__desc {
    font-family: var(--font-body);
    color: var(--text-on-paper);
    font-size: var(--step-0);
    line-height: var(--leading-normal);
  }
  .promo-card__cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--brass);
    padding-top: var(--space-4);
  }
  .promo-card__arrow { transition: transform var(--dur) var(--ease-out-quart); }
  .promo-card__link:hover .promo-card__cta { color: var(--purple); }
  .promo-card__link:hover .promo-card__arrow { transform: translateX(4px); }

  .intro { text-align: left; position: relative; z-index: 1; }
  .intro__lede {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(var(--step-3), 2.5vw + 0.4rem, var(--step-4));
    line-height: var(--leading-snug);
    letter-spacing: var(--track-tight);
    color: var(--ink);
    margin-top: var(--space-4);
    max-width: 38ch;
  }
  .intro__body {
    margin-top: var(--space-5);
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: var(--leading-loose);
    color: var(--text-on-paper);
    max-width: 52ch;
  }

  .eyebrow--brass  { color: var(--brass); }
  .eyebrow--purple { color: var(--purple); }
  .eyebrow--yellow { color: var(--yellow); }
  .eyebrow--copper { color: var(--copper); }

  .sections-index__head { max-width: var(--measure); margin-bottom: var(--space-5); position: relative; z-index: 1; }
  .sections-index__title {
    margin-top: var(--space-3);
    font-size: clamp(var(--step-4), 4vw + 0.4rem, var(--step-6));
    font-weight: 300;
    display: inline-block;
    position: relative;
  }
  .sections-index__title::after {
    content: '';
    position: absolute;
    left: 0; bottom: -0.4em;
    width: 3.5rem;
    height: 3px;
    background: linear-gradient(90deg, var(--purple) 0 60%, var(--yellow) 60% 100%);
  }

  /* 3-column card grid: 5 section cards + 1 decorative fleur cell = 3x2 grid */
  .sections-index__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--paper-hairline);
    border-left: 1px solid var(--paper-hairline);
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .sections-index__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .sections-index__grid { grid-template-columns: 1fr; }
  }

  .sections-index__card {
    border-right: 1px solid var(--paper-hairline);
    border-bottom: 1px solid var(--paper-hairline);
    position: relative;
    background: color-mix(in oklab, var(--paper) 97%, var(--card-accent, var(--brass)) 3%);
    min-width: 0;
  }
  .sections-index__link {
    display: grid;
    grid-template-rows: auto auto auto 1fr auto;
    gap: var(--space-2);
    padding: clamp(var(--space-5), 2.2vw, var(--space-7));
    padding-left: calc(clamp(var(--space-5), 2.2vw, var(--space-7)) + 6px);
    height: 100%;
    border: 0;
    transition: background var(--dur) var(--ease-out-quart);
  }
  .sections-index__link:hover, .sections-index__link:focus-visible {
    background: color-mix(in oklab, var(--card-accent, var(--brass)) 8%, transparent);
  }

  .sections-index__card--brass  { --card-accent: var(--brass); }
  .sections-index__card--purple { --card-accent: var(--purple); }
  .sections-index__card--copper { --card-accent: var(--copper); }
  .sections-index__card--yellow { --card-accent: var(--yellow); }

  /* Colored accent stripe on the left edge of each card */
  .sections-index__card::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--card-accent, var(--brass));
    opacity: 0.9;
  }

  .sections-index__num {
    font-family: var(--font-display);
    font-size: clamp(var(--step-4), 3.4vw, var(--step-5));
    line-height: 0.95;
    color: var(--card-accent, var(--brass));
    font-feature-settings: 'tnum';
    font-weight: 300;
  }
  .sections-index__body { display: contents; }
  .sections-index__kicker {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--card-accent, var(--brass));
    margin-top: var(--space-3);
  }
  .sections-index__label {
    font-family: var(--font-display);
    font-size: clamp(var(--step-3), 2.4vw, var(--step-4));
    font-weight: 400;
    letter-spacing: var(--track-tight);
    line-height: 1;
    color: var(--ink);
    margin-top: var(--space-2);
  }
  .sections-index__blurb {
    font-family: var(--font-body);
    color: var(--text-on-paper);
    font-size: var(--step-0);
    line-height: var(--leading-normal);
    margin-top: var(--space-3);
    max-width: 36ch;
  }
  .sections-index__arrow {
    display: inline-block;
    color: var(--card-accent, var(--brass));
    margin-top: var(--space-5);
    transition: transform var(--dur) var(--ease-out-quart);
  }
  .sections-index__link:hover .sections-index__arrow { transform: translateX(8px); }

  /* Decorative fleur cell filling the 6th slot */
  .sections-index__fleur {
    border-right: 1px solid var(--paper-hairline);
    border-bottom: 1px solid var(--paper-hairline);
    background: color-mix(in oklab, var(--paper) 93%, var(--purple) 7%);
    padding: clamp(var(--space-5), 2vw, var(--space-6));
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100%;
  }
  .sections-index__fleur svg {
    max-width: 200px;
    height: auto;
    opacity: 0.95;
  }
  @media (max-width: 560px) {
    .sections-index__fleur { min-height: 240px; }
  }

  .donate-teaser__inner { text-align: center; position: relative; z-index: 1; }
  .donate-teaser__title {
    font-family: var(--font-display);
    font-size: clamp(var(--step-3), 2.5vw + 0.4rem, var(--step-5));
    margin-top: var(--space-4);
    margin-inline: auto;
    max-width: 24ch;
  }
  .donate-teaser__body {
    margin-inline: auto;
    max-width: 48ch;
    margin-top: var(--space-4);
    font-family: var(--font-body);
    color: var(--text-on-paper);
  }

  .btn {
    display: inline-block;
    margin-top: var(--space-6);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    background: transparent;
    text-decoration: none;
    transition: background var(--dur) var(--ease-out-quart), color var(--dur) var(--ease-out-quart);
  }
  .btn--brass { color: var(--brass); border: 1px solid var(--brass); }
  .btn--brass:hover, .btn--brass:focus-visible { background: var(--brass); color: var(--paper); }
  .btn--purple { color: var(--purple); border: 1px solid var(--purple); }
  .btn--purple:hover, .btn--purple:focus-visible { background: var(--purple); color: var(--paper); }
</style>
