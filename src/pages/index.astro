---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import MusicBackdrop from '../components/MusicBackdrop.astro';
import QuotesCarousel from '../components/QuotesCarousel.astro';
import PlaylistPlayer from '../components/PlaylistPlayer.astro';
import { getEntry } from 'astro:content';

const home = await getEntry('pages', 'home');
const data = (home?.data ?? {}) as any;

/* 26 Boswell Sisters recordings streamed from archive.org's public-domain 78rpm collection. */
const playlist = [
  { title: 'Cheek to Cheek',                                     artist: 'The Boswell Sisters', year: 1935, duration: '2:56', audio: 'https://archive.org/download/78_cheek-to-cheek-with-orch-accomp-the-boswell-sisters/29061%20Cheek%20to%20cheek.mp3' },
  { title: 'Rock and Roll',                                      artist: 'The Boswell Sisters', year: 1934, duration: '2:43', audio: 'https://archive.org/download/78_rock-and-roll-with-orchestra-the-boswell-sisters-clare/23515%20Rock%20and%20Roll.mp3' },
  { title: 'Crazy People',                                       artist: 'The Boswell Sisters', year: 1932, duration: '2:34', audio: 'https://archive.org/download/78_crazy-people-with-guitar-and-bass-accomp-the-boswell-sisters-monaco/30333%20Crazy%20people.mp3' },
  { title: 'Shout, Sister, Shout',                               artist: 'The Boswell Sisters', year: 1931, duration: '3:15', audio: 'https://archive.org/download/78_shout-sister-shout-with-dorsey-brothers-orchestra-the-boswell/30334%20Shout%2C%20sister%2C%20shout.mp3' },
  { title: 'Mood Indigo',                                        artist: 'The Boswell Sisters', year: 1932, duration: '3:22', audio: 'https://archive.org/download/78_mood-indigo_the-boswell-sisters-dorsey-bros-orchestra-ellington-mills-bigard_gbia0429890b/MOOD%20INDIGO%20-%20THE%20BOSWELL%20SISTERS%20-%20DORSEY%20BROS.%27%20ORCHESTRA.mp3' },
  { title: 'Louisiana Hayride',                                  artist: 'The Boswell Sisters', year: 1932, duration: '2:48', audio: 'https://archive.org/download/78_louisiana-hayride_the-boswell-sisters-dorsey-bros-orchestra-dietz-and-schwartz_gbia0429890a/LOUISIANA%20HAYRIDE%20-%20THE%20BOSWELL%20SISTERS%20-%20DORSEY%20BROS.%27%20ORCHESTRA.mp3' },
  { title: 'When I Take My Sugar to Tea',                        artist: 'The Boswell Sisters', year: 1931, duration: '3:10', audio: 'https://archive.org/download/78_when-i-take-my-sugar-to-tea-with-orch-accomp-the-boswell-sisters-fain-kahal/31909%20When%20I%20take%20my%20sugar%20to%20tea.mp3' },
  { title: 'Lullaby of Broadway',                                artist: 'The Boswell Sisters', year: 1935, duration: '2:46', audio: 'https://archive.org/download/78_lullaby-of-broadway-with-piano-accomp-the-boswell-sisters-dubin/29699%20Lullaby%20of%20Broadway.mp3' },
  { title: "The Gold Diggers' Song",                             artist: 'The Boswell Sisters', year: 1933, duration: '2:33', audio: "https://archive.org/download/78_the-gold-diggers-song-acc-by-the-dorsey-brothers-the-boswell/31903%20The%20gold%20diggers%27%20song.mp3" },
  { title: 'Sophisticated Lady',                                 artist: 'The Boswell Sisters', year: 1933, duration: '3:29', audio: 'https://archive.org/download/1933-USA-Archives-1933-00-00-The-Boswell-Sisters-Sophisticated-Lady/1933-USA-Archives-1933-00-00-The-Boswell-Sisters-Sophisticated-Lady.mp3' },
  { title: "Doggone, I've Done It",                              artist: 'The Boswell Sisters', year: 1932, duration: '3:03', audio: "https://archive.org/download/78_doggone-ive-done-it-acc-by-the-dorsey-brothers-the-boswell/31905%20Doggone%20I%27ve%20done%20it.mp3" },
  { title: 'Fare Thee Well',                                     artist: 'The Boswell Sisters', year: 1932, duration: '2:47', audio: 'https://archive.org/download/78_fare-thee-well-with-instr-accomp-the-boswell-sisters-wrubel/31907%20Fare%20thee%20well.mp3' },
  { title: 'Dinah',                                              artist: 'The Boswell Sisters', year: 1932, duration: '2:55', audio: 'https://archive.org/download/78_2879-Dinah/2879-Dinah.mp3' },
  { title: 'Forty-Second Street',                                artist: 'The Boswell Sisters', year: 1933, duration: '3:13', audio: 'https://archive.org/download/78_2405-Forty-second-street/2405-Forty-second-street.mp3' },
  { title: "Alexander's Ragtime Band",                           artist: 'The Boswell Sisters', year: 1935, duration: '2:56', audio: 'https://archive.org/download/78_2880-Alexanders-Ragtime-Band/2880-Alexanders-Ragtime-Band.mp3' },
  { title: 'Shuffle Off to Buffalo',                             artist: 'The Boswell Sisters', year: 1933, duration: '3:03', audio: 'https://archive.org/download/78_2406-Shuffle-off-to-Broadway/2406-Shuffle-off-to-Broadway.mp3' },
  { title: 'Top Hat, White Tie and Tails',                       artist: 'The Boswell Sisters', year: 1935, duration: '3:13', audio: 'https://archive.org/download/78_top-hat-white-tie-and-tails-with-orch-accomp-the-boswell/29063%20Top%20hat%2C%20white%20tie%20and%20tails.mp3' },
  { title: "Don't Let Your Love Go Wrong",                       artist: 'The Boswell Sisters', year: 1934, duration: '2:36', audio: "https://archive.org/download/78_dont-let-your-love-go-wrong_the-boswell-sisters-whiting-schwartz-johnson_gbia7032086b/DON%27T%20LET%20YOUR%20LOVE%20GO%20WRONG%20-%20THE%20BOSWELL%20SISTERS.mp3" },
  { title: "Gee, But I'd Like to Make You Happy",                artist: 'The Boswell Sisters', year: 1931, duration: '3:11', audio: "https://archive.org/download/78_gee-but-id-like-to-make-you-happy_the-three-boswell-sisters-shay-ward-montgomery_gbia3029179a/GEE%2C%20BUT%20I%27D%20LIKE%20TO%20MAKE%20YOU%20HAPPY%20-%20THE%20THREE%20BOSWELL%20SISTERS.mp3" },
  { title: 'Lawd, You Made the Night Too Long',                  artist: 'The Boswell Sisters', year: 1932, duration: '5:21', audio: 'https://archive.org/download/LawdYouMadeTheNightTooLongDonRedmanBingCrosbyBoswellSisters/LawdYouMadeTheNightTooLongDonRedmanBingCrosbyBoswellSisters_vbr.mp3' },
  { title: 'Hand Me Down My Walking Cane',                       artist: 'The Boswell Sisters', year: 1932, duration: '2:51', audio: 'https://archive.org/download/1932-USA-Archives-1932-00-00-Boswell-Sisters-Hand-Me-Down-My-Walking-Kane/1932-USA-Archives-1932-00-00-Boswell-Sisters-Hand-Me-Down-My-Walking-Kane.mp3' },
  { title: 'Old Yazoo',                                          artist: 'The Boswell Sisters', year: 1932, duration: '3:17', audio: 'https://archive.org/download/1932-USA-Archives-1932-00-00-Boswell-Sisters-Old-Yazoo/1932-USA-Archives-1932-00-00-Boswell-Sisters-Old-Yazoo.mp3' },
  { title: "It Don't Mean a Thing (If It Ain't Got That Swing)", artist: 'The Boswell Sisters', year: 1932, duration: '3:22', audio: 'https://archive.org/download/78itdontmeanathingifitaintgotthatswingtheboswellsistersthedorseycleaningbypoofyhairproductions/78ItDontMeanAThingIfItAintGotThatSwingTheBoswellSistersTheDorseyCleaningByPoofyHairProductions.mp3' },
  { title: "I'm All Dressed Up With a Broken Heart",             artist: 'The Boswell Sisters', year: 1925, duration: '3:08', audio: 'https://archive.org/download/1925-USA-Archives-1925-00-00-Boswell-Sisters-Im-All-Dressed-Up-With-A-Broken-Heart/1925-USA-Archives-1925-00-00-Boswell-Sisters-Im-All-Dressed-Up-With-A-Broken-Heart.mp3' },
  { title: 'On the Highway to Heaven',                           artist: 'The Boswell Sisters', year: 1930, duration: '3:13', audio: 'https://archive.org/download/1930-USA-Archives-1930-07-20-Boswell-Sisters-Were-On-The-Highway-To-Heaven/1930-USA-Archives-1930-07-20-Boswell-Sisters-Were-On-The-Highway-To-Heaven.mp3' },
  { title: "Doggone, I've Done It (Again)",                      artist: 'The Boswell Sisters', year: 1932, duration: '3:03', audio: 'https://archive.org/download/1932-USA-Archives-1932-00-00-Boswell-Sisters-Doggone-Ive-Done-It-Again/1932-USA-Archives-1932-00-00-Boswell-Sisters-Doggone-Ive-Done-It-Again.mp3' },
];

/* Quotes carousel — social proof sourced from the site's own content */
const voices = [
  { text: 'The world needs more Boswell Sisters.',                                                                                                                                     attribution: 'Bette Midler' },
  { text: 'There was only one singer who influenced me. I tried to sing like her all the time because everything she did made sense musically, and that singer was Connie Boswell.',   attribution: 'Ella Fitzgerald' },
  { text: 'The way they work out an arrangement is fascinating. One of them plays from an ordinary piano song company, singing the melody. The other two chip in with uncanny instinct.', attribution: 'The Melody Maker' },
  { text: "If it hadn't been for the Boswell Sisters, there would be no Andrews Sisters.",                                                                                             attribution: 'Maxene Andrews' },
  { text: "All these things tended to influence band orchestrations enormously. Glenn Miller even wrote many arrangements from Connee's dictation.",                                   attribution: 'John Lucas' },
];
---
<Base title={data.title as string} description={data.tagline as string | undefined}>
  {/* 1. HERO */}
  <Hero
    title={data.title as string}
    subtitle={data.subtitle as string | undefined}
    image={data.heroImage as string}
    imageAlt={data.heroImageAlt as string | undefined}
    imageCredit={data.heroCredit as string | undefined}
    height="tall"
    layout="split"
  />

  {/* 2. WELCOME / MISSION */}
  {(data.introLede || data.introBody) && (
    <section class="section ground-paper intro-section">
      <MusicBackdrop variant="sheet-music" opacity={0.06} color="var(--purple)" />
      <div class="container-narrow intro">
        {data.introEyebrow && <span class="eyebrow eyebrow--purple">{data.introEyebrow}</span>}
        {data.introLede && <p class="intro__lede">{data.introLede}</p>}
        {Array.isArray(data.introBody)
          ? data.introBody.map((para: string, i: number) => (
              <p class:list={['intro__body', i === 0 && 'intro__body--lead']}>{para}</p>
            ))
          : data.introBody && <p class="intro__body">{data.introBody}</p>}
      </div>
    </section>
  )}

  <SectionDivider variant="jazz" color="purple" />

  {/* 3. MUSIC PLAYLIST */}
  <section class="section ground-paper playlist-section">
    <MusicBackdrop variant="vinyl" opacity={0.05} color="var(--purple)" />
    <div class="container">
      <header class="playlist-section__head">
        <span class="eyebrow eyebrow--purple">Music Playlist</span>
        <h2 class="playlist-section__title">Hear the Boswell Sound</h2>
        <p class="playlist-section__blurb">The Boswell Sisters Collection Volume One.</p>
      </header>
      <PlaylistPlayer tracks={playlist} />
    </div>
  </section>

  {/* 4. VOICES — quotes carousel on purple */}
  <section class="section ground-purple voices-section">
    <MusicBackdrop variant="notes" opacity={0.09} color="var(--yellow-soft)" />
    <div class="container">
      <header class="voices-section__head">
        {data.voicesEyebrow && <span class="eyebrow voices-section__eyebrow">{data.voicesEyebrow}</span>}
        {data.voicesTitle && <h2 class="voices-section__title">{data.voicesTitle}</h2>}
      </header>
      <QuotesCarousel quotes={voices} intervalMs={7000} />
    </div>
  </section>

  {/* 5. SAMPLE THE SOUND — educational lessons CTA */}
  {(data.sampleTitle || data.sampleBody) && (
    <section class="section ground-ink sample-section">
      <MusicBackdrop variant="staves" opacity={0.10} color="var(--yellow-soft)" />
      <div class="container-narrow sample__inner">
        {data.sampleEyebrow && <span class="eyebrow">{data.sampleEyebrow}</span>}
        {data.sampleTitle && <h2 class="sample__title">{data.sampleTitle}</h2>}
        {data.sampleBody && <p class="sample__body">{data.sampleBody}</p>}
        <a href="/media/lessons/1/" class="sample__cta">
          <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="11" fill="none" stroke="currentColor" stroke-width="1.4"/>
            <path d="M9 7 L17 12 L9 17 Z" fill="currentColor"/>
          </svg>
          Play Lesson 1 — The Blend
        </a>
      </div>
    </section>
  )}

  {/* 6. DONATE */}
  {(data.donateTitle || data.donateBody) && (
    <section class="section ground-paper donate-teaser">
      <MusicBackdrop variant="diamond-grid" opacity={0.05} color="var(--purple)" />
      <div class="container-narrow donate-teaser__inner">
        {data.donateEyebrow && <span class="eyebrow eyebrow--purple">{data.donateEyebrow}</span>}
        {data.donateTitle && <h2 class="donate-teaser__title">{data.donateTitle}</h2>}
        {data.donateBody && <p class="donate-teaser__body">{data.donateBody}</p>}
        <a href="https://example.com/donate" target="_blank" rel="noopener noreferrer" class="btn btn--purple">Donate</a>
      </div>
    </section>
  )}
</Base>

<style>
  .intro-section, .playlist-section, .voices-section, .sample-section, .donate-teaser { position: relative; overflow: hidden; }

  /* Welcome / Intro */
  .intro { text-align: left; position: relative; z-index: 1; }
  .intro__lede {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(var(--step-3), 2.5vw + 0.4rem, var(--step-4));
    line-height: var(--leading-snug);
    color: var(--ink);
    margin-top: var(--space-4);
    max-width: 38ch;
  }
  .intro__body {
    margin-top: var(--space-5);
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: var(--leading-loose);
    color: var(--text-on-paper);
    max-width: 52ch;
  }
  .intro__body--lead { font-weight: 700; }

  .eyebrow--brass  { color: var(--brass); }
  .eyebrow--purple { color: var(--purple); }
  .eyebrow--yellow { color: var(--yellow); }
  .eyebrow--copper { color: var(--copper); }

  /* Playlist section */
  .playlist-section__head { text-align: center; margin: 0 auto var(--space-6); position: relative; z-index: 1; }
  .playlist-section__title { margin: var(--space-3) auto 0; font-family: var(--font-display); font-size: clamp(var(--step-4), 3.5vw + 0.3rem, var(--step-6)); font-weight: 300; letter-spacing: var(--track-tight); text-align: center; color: var(--ink); }
  .playlist-section__blurb { margin: var(--space-3) auto 0; font-family: var(--font-body); font-size: var(--step-0); color: var(--ink); max-width: 82ch; text-align: center; }

  /* Voices — purple ground with carousel */
  .voices-section__head { text-align: center; margin: 0 auto var(--space-4); position: relative; z-index: 1; }
  .voices-section__eyebrow { color: var(--yellow-soft); }
  .voices-section__title { margin: var(--space-3) auto 0; font-family: var(--font-display); font-size: clamp(var(--step-4), 3.5vw + 0.3rem, var(--step-6)); font-weight: 300; color: #F5EAD1; text-align: center; max-width: 26ch; }

  /* Sample the Sound (educational lessons) — ink (near-black) ground */
  .sample-section { padding-bottom: clamp(var(--space-8), 6vw, var(--space-9)); }
  .sample__inner { text-align: center; position: relative; z-index: 1; }
  .sample__inner :global(.eyebrow) { color: var(--yellow-soft); }
  .sample__title { margin: var(--space-3) auto 0; font-family: var(--font-display); font-size: clamp(var(--step-4), 3.5vw + 0.3rem, var(--step-5)); font-weight: 300; max-width: 24ch; color: #FFFFFF; }
  .sample__body { margin: var(--space-4) auto 0; max-width: 48ch; font-family: var(--font-body); color: #FFFFFF; }
  .sample__cta {
    display: inline-flex; align-items: center; gap: var(--space-3);
    margin-top: var(--space-6);
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1);
    letter-spacing: var(--track-caps); text-transform: uppercase;
    color: var(--paper); background: var(--purple); border: 1px solid var(--purple);
    text-decoration: none;
    transition: background var(--dur) var(--ease-out-quart), border-color var(--dur) var(--ease-out-quart);
  }
  .sample__cta:hover, .sample__cta:focus-visible { background: var(--oxblood); border-color: var(--oxblood); }

  /* Donate teaser */
  .donate-teaser__inner { text-align: center; position: relative; z-index: 1; }
  .donate-teaser__title {
    font-family: var(--font-display);
    font-size: clamp(var(--step-3), 2.5vw + 0.4rem, var(--step-5));
    margin-top: var(--space-4);
    margin-inline: auto;
    max-width: 24ch;
  }
  .donate-teaser__body {
    margin-inline: auto;
    max-width: 48ch;
    margin-top: var(--space-4);
    font-family: var(--font-body);
    color: var(--text-on-paper);
  }
  .btn {
    display: inline-block;
    margin-top: var(--space-6);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    background: transparent;
    text-decoration: none;
    transition: background var(--dur) var(--ease-out-quart), color var(--dur) var(--ease-out-quart);
  }
  .btn--purple { color: var(--paper); background: var(--purple); border: 1px solid var(--purple); }
  .btn--purple:hover, .btn--purple:focus-visible { background: var(--oxblood); border-color: var(--oxblood); }
</style>
