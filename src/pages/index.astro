---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import MusicBackdrop from '../components/MusicBackdrop.astro';
import QuotesCarousel from '../components/QuotesCarousel.astro';
import PlaylistPlayer from '../components/PlaylistPlayer.astro';
import { getEntry } from 'astro:content';

const home = await getEntry('pages', 'home');
const data = (home?.data ?? {}) as any;

const donateBtn = await getEntry('donate', 'button');
const donateUrl = (donateBtn?.data.url ?? '').trim();
const donateLabel = (donateBtn?.data.label ?? 'Donate').trim();

/* Playlist pulled from the CMS-editable content collection */
const playlistEntry = await getEntry('playlists', 'volume-one');
const playlist = playlistEntry?.data.tracks ?? [];
const playlistCollectionTitle = playlistEntry?.data.title ?? '';

/* Quotes carousel — CMS-editable via the voices collection */
const voicesEntry = await getEntry('voices', 'home');
const voices = voicesEntry?.data.quotes ?? [];
---
<Base title={data.title as string} description={data.tagline as string | undefined}>
  {/* 1. HERO */}
  <Hero
    title={data.title as string}
    subtitle={data.subtitle as string | undefined}
    image={data.heroImage as string}
    imageAlt={data.heroImageAlt as string | undefined}
    imageCredit={data.heroCredit as string | undefined}
    height="tall"
    layout="split"
  />

  {/* 2. WELCOME / MISSION */}
  {(data.introLede || data.introBody) && (
    <section class="section ground-paper intro-section">
      <div class="container-narrow intro">
        {data.introEyebrow && <span class="eyebrow eyebrow--purple">{data.introEyebrow}</span>}
        {data.introLede && <p class="intro__lede">{data.introLede}</p>}
        {Array.isArray(data.introBody)
          ? data.introBody.map((para: string, i: number) => (
              <p class:list={['intro__body', i === 0 && 'intro__body--lead']}>{para}</p>
            ))
          : data.introBody && <p class="intro__body">{data.introBody}</p>}
      </div>
    </section>
  )}

  <SectionDivider variant="jazz" color="purple" />

  {/* 3. MUSIC PLAYLIST */}
  <section class="section ground-paper playlist-section">
    <MusicBackdrop variant="vinyl" opacity={0.05} color="var(--purple)" />
    <div class="container">
      <header class="playlist-section__head">
        {data.playlistEyebrow && <span class="eyebrow eyebrow--purple">{data.playlistEyebrow}</span>}
        {data.playlistTitle && <h2 class="playlist-section__title">{data.playlistTitle}</h2>}
        {playlistCollectionTitle && <p class="playlist-section__blurb">{playlistCollectionTitle}.</p>}
      </header>
      <PlaylistPlayer tracks={playlist} />
    </div>
  </section>

  {/* 4. VOICES — quotes carousel on purple */}
  <section class="section ground-purple voices-section">
    <MusicBackdrop variant="notes" opacity={0.09} color="var(--yellow-soft)" />
    <div class="container">
      <header class="voices-section__head">
        {data.voicesEyebrow && <span class="eyebrow voices-section__eyebrow">{data.voicesEyebrow}</span>}
        {data.voicesTitle && <h2 class="voices-section__title">{data.voicesTitle}</h2>}
      </header>
      <QuotesCarousel quotes={voices} intervalMs={7000} />
    </div>
  </section>

  {/* 5. SAMPLE THE SOUND — educational lessons CTA */}
  {(data.sampleTitle || data.sampleBody) && (
    <section class="section ground-ink sample-section">
      <MusicBackdrop variant="staves" opacity={0.10} color="var(--yellow-soft)" />
      <div class="container-narrow sample__inner">
        {data.sampleEyebrow && <span class="eyebrow">{data.sampleEyebrow}</span>}
        {data.sampleTitle && <h2 class="sample__title">{data.sampleTitle}</h2>}
        {data.sampleBody && <p class="sample__body">{data.sampleBody}</p>}
        <a href="/media/lessons/1/" class="sample__cta">
          <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="11" fill="none" stroke="currentColor" stroke-width="1.4"/>
            <path d="M9 7 L17 12 L9 17 Z" fill="currentColor"/>
          </svg>
          {data.sampleCtaLabel || 'Play Lesson 1'}
        </a>
      </div>
    </section>
  )}

  {/* 6. DONATE */}
  {(data.donateTitle || data.donateBody) && (
    <section class="section ground-paper donate-teaser">
      <MusicBackdrop variant="diamond-grid" opacity={0.05} color="var(--purple)" />
      <div class="container-narrow donate-teaser__inner">
        {data.donateEyebrow && <span class="eyebrow eyebrow--purple">{data.donateEyebrow}</span>}
        {data.donateTitle && <h2 class="donate-teaser__title">{data.donateTitle}</h2>}
        {data.donateBody && <p class="donate-teaser__body">{data.donateBody}</p>}
        <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="btn btn--purple">{donateLabel}</a>
      </div>
    </section>
  )}
</Base>

<style>
  .intro-section, .playlist-section, .voices-section, .sample-section, .donate-teaser { position: relative; overflow: hidden; }

  /* Welcome / Intro */
  .intro { text-align: left; position: relative; z-index: 1; }
  .intro__lede {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(var(--step-3), 2.5vw + 0.4rem, var(--step-4));
    line-height: var(--leading-snug);
    color: var(--ink);
    margin-top: var(--space-4);
    max-width: 38ch;
  }
  .intro__body {
    margin-top: var(--space-5);
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: var(--leading-loose);
    color: var(--text-on-paper);
    max-width: 52ch;
  }
  .intro__body--lead { font-weight: 700; }

  .eyebrow--brass  { color: var(--brass); }
  .eyebrow--purple { color: var(--purple); }
  .eyebrow--yellow { color: var(--yellow); }
  .eyebrow--copper { color: var(--copper); }

  /* Playlist section */
  .playlist-section__head { text-align: center; margin: 0 auto var(--space-6); position: relative; z-index: 1; }
  .playlist-section__title { margin: var(--space-3) auto 0; font-family: var(--font-display); font-size: clamp(var(--step-4), 3.5vw + 0.3rem, var(--step-6)); font-weight: 300; letter-spacing: var(--track-tight); text-align: center; color: var(--ink); }
  .playlist-section__blurb { margin: var(--space-3) auto 0; font-family: var(--font-body); font-size: var(--step-0); color: var(--ink); max-width: 82ch; text-align: center; }

  /* Voices — purple ground with carousel */
  .voices-section__head { text-align: center; margin: 0 auto var(--space-4); position: relative; z-index: 1; }
  .voices-section__eyebrow { color: var(--yellow-soft); }
  .voices-section__title { margin: var(--space-3) auto 0; font-family: var(--font-display); font-size: clamp(var(--step-4), 3.5vw + 0.3rem, var(--step-6)); font-weight: 300; color: #F5EAD1; text-align: center; max-width: 26ch; }

  /* Sample the Sound (educational lessons) — ink (near-black) ground */
  .sample-section { padding-bottom: clamp(var(--space-8), 6vw, var(--space-9)); }
  .sample__inner { text-align: center; position: relative; z-index: 1; }
  .sample__inner :global(.eyebrow) { color: var(--yellow-soft); }
  .sample__title { margin: var(--space-3) auto 0; font-family: var(--font-display); font-size: clamp(var(--step-4), 3.5vw + 0.3rem, var(--step-5)); font-weight: 300; max-width: 24ch; color: #FFFFFF; }
  .sample__body { margin: var(--space-4) auto 0; max-width: 48ch; font-family: var(--font-body); color: #FFFFFF; }
  .sample__cta {
    display: inline-flex; align-items: center; gap: var(--space-3);
    margin-top: var(--space-6);
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1);
    letter-spacing: var(--track-caps); text-transform: uppercase;
    color: var(--paper); background: var(--purple); border: 1px solid var(--purple);
    text-decoration: none;
    transition: background var(--dur) var(--ease-out-quart), border-color var(--dur) var(--ease-out-quart);
  }
  .sample__cta:hover, .sample__cta:focus-visible { background: var(--oxblood); border-color: var(--oxblood); }

  /* Donate teaser */
  .donate-teaser__inner { text-align: center; position: relative; z-index: 1; }
  .donate-teaser__title {
    font-family: var(--font-display);
    font-size: clamp(var(--step-3), 2.5vw + 0.4rem, var(--step-5));
    margin-top: var(--space-4);
    margin-inline: auto;
    max-width: 24ch;
  }
  .donate-teaser__body {
    margin-inline: auto;
    max-width: 48ch;
    margin-top: var(--space-4);
    font-family: var(--font-body);
    color: var(--text-on-paper);
  }
  .btn {
    display: inline-block;
    margin-top: var(--space-6);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    background: transparent;
    text-decoration: none;
    transition: background var(--dur) var(--ease-out-quart), color var(--dur) var(--ease-out-quart);
  }
  .btn--purple { color: var(--paper); background: var(--purple); border: 1px solid var(--purple); }
  .btn--purple:hover, .btn--purple:focus-visible { background: var(--oxblood); border-color: var(--oxblood); }
</style>
