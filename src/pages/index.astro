---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const entry = await getEntry('page', 'home');
if (!entry) throw new Error('Missing content/page/home.md');
const { Content } = await render(entry);
---
<Base title={entry.data.title} heroImage={entry.data.heroImage}>
  <Content />
</Base>
