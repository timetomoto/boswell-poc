---
import Base from '../../../layouts/Base.astro';
import MusicBackdrop from '../../../components/MusicBackdrop.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(a => {
    const subhub = a.data.subhub;
    // Strip the subhub prefix from the file id to get a clean URL slug
    const slug = a.id.replace(new RegExp(`^${subhub}[-_]?`), '') || a.id;
    return {
      params: { subhub, slug },
      props: { article: a },
    };
  });
}

const { article } = Astro.props;
const { Content: ArticleContent } = await render(article);

/* Human-readable subhub label */
const SUBHUB_LABEL: Record<string, string> = {
  vintage: 'Vintage Articles',
  'in-their-own-words': 'In Their Own Words',
  video: 'Video Features',
  feature: 'Features',
  essay: 'About the Site',
};
const subhubLabel = SUBHUB_LABEL[article.data.subhub] ?? article.data.subhub;

/* Prev / next within the same subhub */
const all = (await getCollection('articles'))
  .filter(a => a.data.subhub === article.data.subhub)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const currentIdx = all.findIndex(a => a.id === article.id);
const prev = all.length > 1 ? (currentIdx > 0 ? all[currentIdx - 1] : all[all.length - 1]) : null;
const next = all.length > 1 ? (currentIdx < all.length - 1 ? all[currentIdx + 1] : all[0]) : null;
const stripPrefix = (id: string, sh: string) => id.replace(new RegExp(`^${sh}[-_]?`), '') || id;
---
<Base title={article.data.title} description={article.data.pullQuote}>
  <section class="article-hero ground-purple">
    <MusicBackdrop variant="notes" opacity={0.07} color="var(--yellow-soft)" />
    <div class="container-narrow article-hero__inner">
      <a href="/press/" class="article-hero__back">← Press · {subhubLabel}</a>
      <h1 class="article-hero__title">{article.data.title}</h1>
      {(article.data.author || article.data.publication || article.data.publicationDate) && (
        <p class="article-hero__meta">
          {[article.data.author, article.data.publication, article.data.publicationDate].filter(Boolean).join(' · ')}
        </p>
      )}
      {article.data.pullQuote && (
        <blockquote class="article-hero__quote">
          <span aria-hidden="true">"</span>{article.data.pullQuote}<span aria-hidden="true">"</span>
          {article.data.pullQuoteAttribution && <cite>— {article.data.pullQuoteAttribution}</cite>}
        </blockquote>
      )}
    </div>
  </section>

  <section class="section ground-paper">
    <div class="container-narrow prose article-body">
      {article.data.videoEmbed && (
        <div class="video-embed">
          <iframe src={article.data.videoEmbed} title={article.data.title} allowfullscreen loading="lazy"></iframe>
        </div>
      )}
      <ArticleContent />
      {article.data.externalLink && (
        <p class="article-external">
          <a href={article.data.externalLink} target="_blank" rel="noopener noreferrer">Read the original →</a>
        </p>
      )}
    </div>
  </section>

  {(prev || next) && (
    <nav class="section-tight ground-paper article-nav" aria-label="Articles navigation">
      <div class="container article-nav__inner">
        {prev && (
          <a href={`/press/${prev.data.subhub}/${stripPrefix(prev.id, prev.data.subhub)}/`} class="article-nav__link article-nav__link--prev">
            <span class="article-nav__label">Previous</span>
            <span class="article-nav__title">{prev.data.title}</span>
          </a>
        )}
        <a href="/press/" class="article-nav__link article-nav__link--all">
          <span class="article-nav__label">All</span>
          <span class="article-nav__title">Press</span>
        </a>
        {next && (
          <a href={`/press/${next.data.subhub}/${stripPrefix(next.id, next.data.subhub)}/`} class="article-nav__link article-nav__link--next">
            <span class="article-nav__label">Next</span>
            <span class="article-nav__title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}
</Base>

<style>
  .article-hero { padding-block: clamp(var(--space-6), 4vw, var(--space-8)); position: relative; overflow: hidden; }
  .article-hero__inner { position: relative; z-index: 1; }
  .article-hero__back {
    display: block; width: fit-content;
    font-family: var(--font-ui); font-weight: 500;
    font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase;
    color: var(--yellow-soft); border: 0;
    margin-bottom: var(--space-5);
  }
  .article-hero__back:hover { color: var(--yellow-hover); }
  .article-hero__title {
    font-family: var(--font-display); font-weight: 300;
    font-size: clamp(var(--step-5), 5vw + 0.3rem, var(--step-7));
    line-height: 1.05; letter-spacing: var(--track-tight);
    color: var(--paper-warm); margin: 0;
    max-width: 28ch;
  }
  .article-hero__meta {
    margin-top: var(--space-4);
    font-family: var(--font-ui); font-weight: 500;
    font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase;
    color: var(--yellow-soft);
  }
  .article-hero__quote {
    margin-top: var(--space-5);
    font-family: var(--font-ui);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(var(--step-1), 1.2vw + 0.3rem, var(--step-2));
    line-height: var(--leading-normal);
    color: #FBF3D6;
    max-width: 52ch;
    padding-left: var(--space-4);
    border-left: 3px solid var(--yellow-soft);
  }
  .article-hero__quote cite {
    display: block;
    margin-top: var(--space-2);
    font-family: var(--font-ui); font-style: normal; font-weight: 500;
    font-size: var(--step--2); letter-spacing: var(--track-caps); text-transform: uppercase;
    color: var(--yellow-soft);
  }

  /* Prose block */
  .prose { font-family: var(--font-body); font-size: var(--step-1); line-height: var(--leading-loose); color: var(--text-on-paper); }
  .prose :global(p) { max-width: 62ch; }
  .prose :global(p) + :global(p), .prose :global(p) + :global(h2), .prose :global(p) + :global(h3), .prose :global(p) + :global(h4) { margin-top: var(--space-4); }
  .prose :global(h2), .prose :global(h3), .prose :global(h4) { margin-top: var(--space-6); margin-bottom: var(--space-3); font-family: var(--font-display); font-weight: 400; letter-spacing: var(--track-tight); }
  .prose :global(h2) { font-size: var(--step-3); }
  .prose :global(h3) { font-size: var(--step-2); }
  .prose :global(h4) { font-size: var(--step--1); font-family: var(--font-ui); font-weight: 500; letter-spacing: var(--track-caps); text-transform: uppercase; color: var(--purple); margin-top: var(--space-8); margin-bottom: var(--space-4); }
  .prose :global(img) { max-width: 100%; height: auto; margin: var(--space-4) 0; }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(em), .prose :global(i) { font-family: var(--font-ui); font-style: italic; color: var(--purple); }
  .prose :global(blockquote) { border-left: 3px solid var(--brass); padding-left: var(--space-4); margin: var(--space-5) 0; font-family: var(--font-ui); font-style: italic; font-size: var(--step-0); line-height: var(--leading-normal); color: var(--oxblood); }
  .prose :global(table) { border-collapse: collapse; margin: var(--space-4) 0; width: 100%; max-width: 62ch; font-size: var(--step-0); }
  .prose :global(td), .prose :global(th) { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--paper-hairline); vertical-align: top; }

  .video-embed {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    margin: var(--space-4) 0 var(--space-6);
    background: var(--ink);
  }
  .video-embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

  .article-external { margin-top: var(--space-6); font-family: var(--font-ui); font-weight: 500; font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase; }

  /* Prev / All / Next */
  .article-nav { border-top: 1px solid var(--paper-hairline); }
  .article-nav__inner { display: grid; grid-template-columns: 1fr auto 1fr; gap: var(--space-5); align-items: center; }
  .article-nav__link { display: inline-flex; flex-direction: column; gap: var(--space-1); border: 0; padding-block: var(--space-3); max-width: 22rem; }
  .article-nav__link--prev { text-align: left; }
  .article-nav__link--all { text-align: center; }
  .article-nav__link--next { text-align: right; justify-self: end; }
  .article-nav__label { font-family: var(--font-ui); font-weight: 500; font-size: var(--step--2); letter-spacing: var(--track-caps); text-transform: uppercase; color: var(--text-on-paper-muted); }
  .article-nav__title { font-family: var(--font-display); font-size: var(--step-1); color: var(--ink); line-height: 1.15; }
  @media (max-width: 640px) {
    .article-nav__inner { grid-template-columns: 1fr; text-align: center; }
    .article-nav__link { text-align: center; justify-self: center; max-width: none; }
  }
</style>
