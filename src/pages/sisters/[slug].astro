---
import Base from '../../layouts/Base.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import MusicBackdrop from '../../components/MusicBackdrop.astro';
import Timeline from '../../components/Timeline.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const sisters = await getCollection('sisters');
  return sisters.map(s => ({ params: { slug: s.id }, props: { sister: s } }));
}

const { sister } = Astro.props;
const { Content: BioContent } = await render(sister);

// Connee's bio embeds her solo career timeline
let conneeTimeline = null;
if (sister.id === 'connee') {
  conneeTimeline = await getEntry('timelines', 'connee');
}

/* Facts panel — turn frontmatter into label/value pairs. Human-readable labels. */
const factsMap: Record<string, string> = {
  born: 'Born',
  died: 'Died',
  hairColor: 'Hair',
  eyeColor: 'Eyes',
  complexion: 'Complexion',
  height: 'Height',
  marriage: 'Marriage',
  children: 'Children',
};
const factsRaw = (sister.data as any).facts ?? {};
const factsList = Object.entries(factsMap)
  .filter(([k]) => factsRaw[k])
  .map(([k, label]) => ({ label, value: factsRaw[k] as string }));

// Locate next / prev sisters for footer navigation
const all = (await getCollection('sisters')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
const currentIdx = all.findIndex(s => s.id === sister.id);
const prev = currentIdx > 0 ? all[currentIdx - 1] : all[all.length - 1];
const next = currentIdx < all.length - 1 ? all[currentIdx + 1] : all[0];
---
<Base title={sister.data.name} description={sister.data.pullQuote}>
  {/* Compact purple hero — no image, big display type + pull quote */}
  <section class="bio-hero ground-purple">
    <MusicBackdrop variant="staves" opacity={0.07} color="var(--yellow-soft)" />
    <div class="container-narrow bio-hero__inner">
      <a href="/sisters/" class="bio-hero__back">← The Sisters</a>
      <span class="eyebrow bio-hero__eyebrow">{sister.data.nickname}</span>
      <h1 class="bio-hero__name">{sister.data.name}</h1>
      {sister.data.pullQuote && (
        <blockquote class="bio-hero__quote">
          <span aria-hidden="true">"</span>{sister.data.pullQuote}<span aria-hidden="true">"</span>
          {sister.data.pullQuoteAttribution && (
            <cite>— {sister.data.pullQuoteAttribution}</cite>
          )}
        </blockquote>
      )}
    </div>
  </section>

  {factsList.length > 0 && (
    <section class="section-tight ground-paper facts-strip">
      <div class="container">
        <dl class="facts">
          {factsList.map(f => (
            <div class="facts__pair">
              <dt class="facts__label">{f.label}</dt>
              <dd class="facts__value">{f.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )}

  <section class="section ground-paper bio-body">
    <div class="container bio-body__layout">
      {sister.data.portrait && (
        <figure class="bio-portrait">
          <img
            src={sister.data.portrait}
            alt={sister.data.portraitAlt ?? sister.data.name}
            loading="lazy"
          />
          <figcaption class="bio-portrait__caption">{sister.data.name}</figcaption>
        </figure>
      )}
      <div class="prose">
        <BioContent />
      </div>
    </div>
  </section>

  {conneeTimeline && (
    <>
      <SectionDivider variant="jazz" color="purple" />
      <section class="section ground-paper bio-timeline">
        <div class="container">
          <header class="bio-timeline__head">
            <span class="eyebrow eyebrow--purple">The Solo Years</span>
            <h2 class="bio-timeline__title">{conneeTimeline.data.title}</h2>
          </header>
          <Timeline entries={conneeTimeline.data.entries ?? []} color="purple" />
        </div>
      </section>
    </>
  )}


  <nav class="section-tight ground-paper bio-nav" aria-label="Sisters navigation">
    <div class="container bio-nav__inner">
      <a href={`/sisters/${prev.id}/`} class="bio-nav__link bio-nav__link--prev">
        <span class="bio-nav__label">Previous</span>
        <span class="bio-nav__name">{prev.data.name}</span>
      </a>
      <a href="/sisters/" class="bio-nav__link bio-nav__link--all">
        <span class="bio-nav__label">All</span>
        <span class="bio-nav__name">The Sisters</span>
      </a>
      <a href={`/sisters/${next.id}/`} class="bio-nav__link bio-nav__link--next">
        <span class="bio-nav__label">Next</span>
        <span class="bio-nav__name">{next.data.name}</span>
      </a>
    </div>
  </nav>
</Base>

<style>
  /* Bio hero — purple, no image, editorial */
  .bio-hero { padding-block: clamp(var(--space-6), 4vw, var(--space-8)); position: relative; overflow: hidden; }
  .bio-hero__inner { position: relative; z-index: 1; }
  .bio-hero__back {
    display: block;
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--yellow-soft);
    border: 0;
    margin-bottom: var(--space-5);
    width: fit-content;
  }
  .bio-hero__back:hover { color: var(--yellow-hover); }
  .bio-hero__eyebrow { color: var(--yellow-soft); }
  .bio-hero__name {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(var(--step-6), 7vw, var(--step-8));
    line-height: 0.95;
    letter-spacing: var(--track-tight);
    color: var(--paper-warm);
    margin-top: var(--space-2);
  }
  .bio-hero__quote {
    margin-top: var(--space-5);
    font-family: var(--font-ui);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(var(--step-1), 1.2vw + 0.3rem, var(--step-2));
    line-height: var(--leading-normal);
    color: #FBF3D6;
    max-width: 52ch;
  }
  .bio-hero__quote cite {
    display: block;
    margin-top: var(--space-3);
    font-family: var(--font-ui);
    font-style: normal;
    font-weight: 500;
    font-size: var(--step--1);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--yellow-soft);
  }

  .bio-body { position: relative; }

  /* Two-column bio body: portrait left, prose right */
  .bio-body__layout {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: clamp(var(--space-5), 3vw, var(--space-7));
    align-items: start;
    max-width: var(--measure-wide);
    margin-inline: auto;
  }
  @media (max-width: 820px) {
    .bio-body__layout { grid-template-columns: 1fr; }
  }
  .bio-portrait {
    margin: 0;
    width: 300px;
    max-width: 100%;
    position: sticky;
    /* Clear the sticky site nav (~80px tall) plus a little breathing room */
    top: calc(80px + var(--space-3));
    align-self: start;
  }
  .bio-portrait img {
    display: block;
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: center 20%;
    filter: grayscale(0.4) contrast(1.05);
    border: 1px solid var(--paper-hairline);
    box-shadow: 0 8px 20px -12px rgba(24, 22, 21, 0.35);
  }
  .bio-portrait__caption {
    margin-top: var(--space-2);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--2);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--purple);
    text-align: center;
  }
  @media (max-width: 820px) {
    .bio-portrait { position: static; margin-bottom: var(--space-4); }
  }

  /* Facts strip: definition list rendered as a responsive grid, museum-label feel */
  .facts-strip { border-bottom: 1px solid var(--paper-hairline); background: color-mix(in oklab, var(--paper) 96%, var(--purple) 4%); }
  .facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: clamp(var(--space-3), 1.5vw, var(--space-5));
    margin: 0;
  }
  .facts__pair {
    display: grid;
    grid-template-rows: auto auto;
    gap: var(--space-1);
    padding-left: var(--space-3);
    border-left: 2px solid var(--purple);
  }
  .facts__label {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--2);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--purple);
    margin: 0;
  }
  .facts__value {
    font-family: var(--font-body);
    font-size: var(--step-0);
    color: var(--text-on-paper);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .bio-timeline { position: relative; overflow: hidden; background: color-mix(in oklab, var(--paper) 96%, var(--purple) 4%); }
  .bio-timeline__head { max-width: var(--measure-wide); margin: 0 auto var(--space-5); text-align: center; }
  .bio-timeline__title {
    margin-top: var(--space-2);
    font-family: var(--font-display);
    font-size: clamp(var(--step-4), 3vw + 0.3rem, var(--step-5));
    font-weight: 300;
    letter-spacing: var(--track-tight);
  }

  /* Prose — same treatment as landing */
  .prose { font-family: var(--font-body); font-size: var(--step-1); line-height: var(--leading-loose); color: var(--text-on-paper); position: relative; z-index: 1; }
  .prose :global(p) { max-width: 62ch; }
  .prose :global(p) + :global(p),
  .prose :global(p) + :global(h2),
  .prose :global(p) + :global(h3),
  .prose :global(p) + :global(h4) { margin-top: var(--space-4); }
  .prose :global(h2), .prose :global(h3), .prose :global(h4) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: var(--track-tight);
  }
  .prose :global(h2) { font-size: var(--step-3); }
  .prose :global(h3) { font-size: var(--step-2); }
  .prose :global(h4) {
    font-size: var(--step--1);
    font-family: var(--font-ui);
    font-weight: 500;
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--purple);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }
  .prose :global(img) { max-width: 100%; height: auto; margin: var(--space-4) 0; }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(table) { border-collapse: collapse; margin: var(--space-4) 0; width: 100%; max-width: 62ch; font-size: var(--step-0); }
  .prose :global(td), .prose :global(th) { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--paper-hairline); vertical-align: top; }
  .prose :global(td:first-child), .prose :global(th:first-child) { color: var(--purple); font-family: var(--font-ui); font-weight: 500; white-space: nowrap; font-size: var(--step--1); letter-spacing: var(--track-caps); text-transform: uppercase; }
  .prose :global(blockquote) { border-left: 3px solid var(--brass); padding-left: var(--space-4); margin: var(--space-5) 0; font-family: var(--font-ui); font-style: italic; font-size: var(--step-0); line-height: var(--leading-normal); color: var(--oxblood); }
  .prose :global(em), .prose :global(i) { font-family: var(--font-ui); font-style: italic; color: var(--purple); }

  /* Sisters bottom nav */
  .bio-nav { border-top: 1px solid var(--paper-hairline); }
  .bio-nav__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .bio-nav__link {
    display: inline-flex;
    flex-direction: column;
    gap: var(--space-1);
    border: 0;
    padding-block: var(--space-3);
  }
  .bio-nav__link--prev { text-align: left; }
  .bio-nav__link--all { text-align: center; }
  .bio-nav__link--next { text-align: right; justify-self: end; }
  .bio-nav__label {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--step--2);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--text-on-paper-muted);
  }
  .bio-nav__name {
    font-family: var(--font-display);
    font-size: var(--step-2);
    color: var(--ink);
  }
  @media (max-width: 640px) {
    .bio-nav__inner { grid-template-columns: 1fr; text-align: center; }
    .bio-nav__link { text-align: center; justify-self: center; }
  }
</style>
